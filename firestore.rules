rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net: default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Regra para anotações de desenvolvimento (qualquer usuário autenticado pode acessar)
    match /dev_improvements/{id} {
      allow read, write: if request.auth != null;
    }

    // Regras para coleções do usuário (qualquer usuário autenticado pode acessar, segregação garantida no nível de aplicação)
    match /medicamentos/{id} {
      allow read, write: if true;
    }
    
    match /procedures/{id} {
      allow read, write: if true;
    }

    match /providers/{id} {
      allow read, write: if request.auth != null;
    }

    match /procedureTypes/{id} {
      allow read, write: if request.auth != null;
    }

    match /familiars/{id} {
      allow read, write: if true;
    }

    match /categories/{id} {
      allow read, write: if request.auth != null;
    }

    match /tratamentos/{id} {
      allow read, write: if request.auth != null;
    }

    match /email_logs/{id} {
      allow read, write: if true;
    }

    match /app_settings/stock_routine {
      allow read: if true;
      allow write: if true;
    }

    match /app_settings/stock_routine_secrets {
      allow read, write: if true;
    }

    match /app_settings/{id} {
      allow read, write: if true;
    }
  }
}
